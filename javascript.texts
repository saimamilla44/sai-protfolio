simple if
*********
it is a condition statement used to decide whether a certain  
statement or blockof statement will be execute or not

syntax:
        var a =20;
if(a){
    console.log("a is there",a);
}else{
    console.log("a is 0 or not there");
}


nested if statement
******************
if(condition 1)
{
    if (condition 2)
    {
        statement 1;
    }
    else
    {
        statement 2;
    }
}
else
{
    statement 3;
}

syntax:var a = 60;
if(a == 20)
{
    console.log('equal to 20');

}
else if(a==30)
 {
    console.log("equals to 30");
 }
 else if(a==40)
 {
    console.log("equals to 40");
 }
 else if (a==50)
    {
        console.log("equals to 50");
    }  
    else
        {
            console.log("not equals to 20/30/40/50");
    }


