logical operator
*******************
!(logical not)  (!!Double negetion)
||(logical OR)
&&(logical AND)

consol.log(!undefined)//true
consol.log(!null)//true
consol.log(!20)//false
consol.log(!0)//true
consol.log(!NAN)//true
consol.log(!{})//false
consol.log(!");//true
consol.log(!text);//true
consol.log(text);//false
consol.log(true);//false
consol.log(false);//true

var a=10||20
consol.log(a);//10

var b=20&&30
consol.log(b);//20

var x=0||10
consol.log(x);//0

var y=10||30
consol.log(y);//30

var a,b=10&&20;//undefined  20
a+=b;//NAN
console.log(a,b);//nan 20

var x=10 || 20,y=30 && 40;
x +=y;//50
console.log(x,y);//50 40

var c=0||10 && 0 ||30 && 40;
console.log(c);//40


